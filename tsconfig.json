{
  "compilerOptions": {
    /* Dasar */
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2020"
    ],
    /* Output */
    "outDir": "./dist",
    "rootDir": "./",
    /* Deklarasi Tipe (Penting untuk Library) */
    "declaration": true, // Menghasilkan file .d.ts
    "declarationMap": true, // Memungkinkan user "Go to Definition" ke source code Anda
    "sourceMap": true, // Membantu debugging bagi user
    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
  ], // Hanya compile file di folder src
  "exclude": [
    "node_modules",
    "dist"
  ]
}